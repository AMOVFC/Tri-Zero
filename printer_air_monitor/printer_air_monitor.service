[Unit]
Description=Printer Air Monitor
After=multi-user.target

[Service]
Type=simple
User=andre
WorkingDirectory=/home/andre/printer_air_monitor
ExecStart=/home/andre/printer_air_monitor/.venv/bin/python /home/andre/printer_air_monitor/air_monitor.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
