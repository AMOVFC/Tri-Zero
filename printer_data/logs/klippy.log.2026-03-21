voltage1 = 1.91
temperature2 = 240
voltage2 = 3.82

[temperature_sensor Hotend_power]
sensor_pin = orbitoolO2S:PA0
sensor_type = HOT_P

[neopixel OrbiLED]
pin = orbitoolO2S:PC15
chain_count = 2
color_order = GRB
initial_red = 0.0
initial_green = 0.0
initial_blue = 0.1

[fan]
pin = !orbitoolO2S:PA10
enable_pin = orbitoolO2S:PB14

[temperature_sensor toolboard]
sensor_type = temperature_mcu
sensor_mcu = orbitoolO2S

[output_pin T0_RUN_LED]
pin = orbitoolO2S:PB13
value = 1
shutdown_value = 0

[adxl345]
cs_pin = orbitoolO2S:PA4
spi_bus = spi1
axes_map = y, z, x
spi_speed = 5000000

[resonance_tester]
accel_chip = adxl345
sweeping_period = 0.5
probe_points = 
	60, 60, 100

[duplicate_pin_override]
pins = PA1

[heater_bed]
heater_pin = PG11
sensor_pin = PA1
pullup_resistor = 2200
sensor_type = Generic 3950
smooth_time = 3.0
max_power = 1
min_temp = 0
max_temp = 120
control = pid
pid_kp = 68.737
pid_ki = 1.172
pid_kd = 1007.853

[controller_fan Fan_Right]
pin = PF7
tachometer_pin = PF6
tachometer_ppr = 2
stepper = stepper_x, stepper_y
fan_speed = 1.0
kick_start_time = 0.5
idle_timeout = 30
idle_speed = 0.3

[controller_fan Fan_Left]
pin = PF9
tachometer_pin = PF8
tachometer_ppr = 2
stepper = stepper_x, stepper_y
fan_speed = 1.0
kick_start_time = 0.5
idle_timeout = 30
idle_speed = 0.3

[output_pin caselight]
pin = PE6
pwm = true
shutdown_value = 0
cycle_time = 0.01

[idle_timeout]
timeout = 1800

[homing_override]
axes = xyz
set_position_z = 25
gcode = 
	G91
	G0 Z5 F2000
	G90
	{% set home_all = 'X' not in params and 'Y' not in params and 'Z' not in params %}
	{% set e_target = printer.extruder.target %}
	{% set fan_speed = printer.fan.speed %}
	
	{% if home_all or 'X' in params %}
	_HOME_X
	{% endif %}
	
	{% if home_all or 'Y' in params %}
	_HOME_Y
	{% endif %}
	
	{% if home_all or 'Z' in params %}
	G0 X{printer.toolhead.axis_maximum.x / 2} Y{printer.toolhead.axis_maximum.y / 2} F6000
	{% if e_target >= 180 or printer.extruder.temperature >= 180 %}
	M106 S255
	M109 S180
	{% endif %}
	M106 S0
	
	G91
	G1 Z5 F2000
	G90
	
	
	
	G28 Z
	
	G1 Z10 F2000
	
	M109 S{e_target}
	M106 S{fan_speed}
	{% endif %}

[z_tilt]
z_positions = 
	150, -5
	-30, -5
	60, 150
points = 
	115, 5
	5, 5
	60, 115
speed = 100
horizontal_move_z = 5
retries = 3
retry_tolerance = 0.05

[bed_mesh]
speed = 100
horizontal_move_z = 3
mesh_min = 15, 15
mesh_max = 105, 105
probe_count = 3, 3
algorithm = bicubic
bicubic_tension = 0.2

[output_pin _probe_ready]
pin = PA10
shutdown_value = 0
value = 0

[probe]
pin = ^PA9
x_offset = 0
y_offset = 0
z_offset = 0
speed = 5
samples = 3
samples_result = median
sample_retract_dist = 2
samples_tolerance = 0.05
samples_tolerance_retries = 10
activate_gcode = 
	G4 P500
	SET_PIN PIN=_probe_ready VALUE=1
deactivate_gcode = 
	SET_PIN PIN=_probe_ready VALUE=0

[bed_mesh 5x5]
version = 1
points = 
	-0.178750, -0.272500, -0.107500, -0.343750, -0.107500
	-0.032500, -0.158750, 0.020000, -0.356250, 0.036250
