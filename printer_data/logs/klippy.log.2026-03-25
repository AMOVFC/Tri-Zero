sweeping_period = 0.5
probe_points = 
	60, 60, 100

[duplicate_pin_override]
pins = PA1

[heater_bed]
heater_pin = PG11
sensor_pin = PA1
pullup_resistor = 2200
sensor_type = Generic 3950
smooth_time = 3.0
max_power = 1
min_temp = 0
max_temp = 120
control = pid
pid_kp = 68.737
pid_ki = 1.172
pid_kd = 1007.853

[controller_fan Fan_Right]
pin = PF7
tachometer_pin = PF6
tachometer_ppr = 2
stepper = stepper_x, stepper_y
fan_speed = 1.0
kick_start_time = 0.5
idle_timeout = 30
idle_speed = 0.3

[controller_fan Fan_Left]
pin = PF9
tachometer_pin = PF8
tachometer_ppr = 2
stepper = stepper_x, stepper_y
fan_speed = 1.0
kick_start_time = 0.5
idle_timeout = 30
idle_speed = 0.3

[output_pin caselight]
pin = PE6
pwm = true
shutdown_value = 0
cycle_time = 0.01

[idle_timeout]
timeout = 1800

[homing_override]
axes = xyz
set_position_z = 25
gcode = 
	G91
	G0 Z5 F2000
	G90
	{% set home_all = 'X' not in params and 'Y' not in params and 'Z' not in params %}
	{% set e_target = printer.extruder.target %}
	{% set fan_speed = printer.fan.speed %}
	
	{% if home_all or 'X' in params %}
	_HOME_X
	{% endif %}
	
	{% if home_all or 'Y' in params %}
	_HOME_Y
	{% endif %}
	
	{% if home_all or 'Z' in params %}
	G0 X{printer.toolhead.axis_maximum.x / 2} Y{printer.toolhead.axis_maximum.y / 2} F6000
	{% if e_target >= 180 or printer.extruder.temperature >= 180 %}
	M106 S255
	M109 S180
	{% endif %}
	M106 S0
	
	G91
	G1 Z5 F2000
	G90
	
	
	
	G28 Z
	
	G1 Z10 F2000
	
	M109 S{e_target}
	M106 S{fan_speed}
	{% endif %}

