dir_pin = !PD3
enable_pin = !PD7
endstop_pin = probe:z_virtual_endstop
rotation_distance = 32
microsteps = 32
position_max = 100
position_min = -25
homing_speed = 5
second_homing_speed = 3.0
homing_retract_dist = 2.0
homing_positive_dir = false

[tmc2209 stepper_z]
uart_pin = PD5
interpolate = false
run_current = 0.8
sense_resistor = 0.110
stealthchop_threshold = 0

[stepper_z1]
