spi_bus = spi4
diag0_pin = ^!PE10
interpolate = true
run_current = 2
sense_resistor = 0.075
stealthchop_threshold = 0
driver_sgt = 2
driver_tbl = 0
driver_toff = 3
driver_hstrt = 4
driver_hend = 3

[stepper_z]
