x_offset = 0
y_offset = 0
z_offset = 0
speed = 5
samples = 3
samples_result = median
sample_retract_dist = 2
samples_tolerance = 0.05
samples_tolerance_retries = 10
activate_gcode = 
	G4 P500
	SET_PIN PIN=_probe_ready VALUE=1
deactivate_gcode = 
