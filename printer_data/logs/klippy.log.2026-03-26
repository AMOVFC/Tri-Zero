dir_pin = !PF14
enable_pin = !PE9
rotation_distance = 40
microsteps = 16
full_steps_per_rotation = 200
endstop_pin = tmc5160_stepper_y:virtual_endstop
position_endstop = 120
position_max = 120
homing_speed = 90
homing_retract_dist = 0
homing_positive_dir = true

[tmc5160 stepper_y]
