[mqtt]
address = 127.0.0.1
port = 1883

[sensor chamber_env]
type = mqtt
name = Chamber Env
parameter_temperature = 
	units=C
parameter_humidity = 
	units=%
parameter_voc_index = 
	units=PPCM
state_topic = printer/air_monitor/state
state_response_template = 
	{% set d = payload|fromjson %}
	{set_result("temperature", d["temperature"]|float)}
	{set_result("humidity", d["humidity"]|float)}
	{set_result("voc_index", d["voc_index"]|float)}

